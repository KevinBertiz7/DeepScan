{
  "uid": "deepscan-security",
  "title": "DeepScan Security Dashboard",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total analisis realizados",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "deepscan_analyses_total", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Amenazas detectadas",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "deepscan_threats_detected_total", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errores",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "deepscan_errors_total", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tiempo promedio de analisis",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(deepscan_analysis_duration_seconds_sum[5m]) / rate(deepscan_analysis_duration_seconds_count[5m])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Uso de memoria",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests por minuto",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(deepscan_http_requests_total[1m]))",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "type": "dashboard",
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true
      }
    ]
  }
}
